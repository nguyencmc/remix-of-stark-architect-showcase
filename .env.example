# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and update with your Supabase project values.
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
#
# For DigitalOcean App Platform:
#   1. Go to App Settings → App-Level Environment Variables
#   2. Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
#   3. Set scope to BUILD_TIME, type to SECRET
#   4. Redeploy the app
#   See: https://docs.digitalocean.com/products/app-platform/how-to/use-environment-variables/
#
# For Docker:
#   docker build \
#     --build-arg VITE_SUPABASE_URL=https://xxx.supabase.co \
#     --build-arg VITE_SUPABASE_ANON_KEY=eyJ... \
#     -t ai-exam-cloud .
# =============================================================================

# Supabase Configuration (required)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
